{
  "name": "custom-module-reviewer",
  "version": "0.1.0",
  "description": "Generate module-specific Claude Code review skills from Bugzilla + Phabricator history.",
  "type": "module",
  "bin": {
    "custom-module-reviewer": "./bin/custom-module-reviewer.ts"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "check": "bun run lint && bun run typecheck && bun run test:coverage",
    "start": "bun run bin/custom-module-reviewer.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "commander": "^12.1.0",
    "p-limit": "^6.1.0",
    "picomatch": "^4.0.2",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/picomatch": "^3.0.1",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-unicorn": "^56.0.1",
    "typescript": "^5.6.3"
  }
}
